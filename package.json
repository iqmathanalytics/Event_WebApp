{
  "name": "city-events-lifestyle-hub-backend",
  "version": "1.0.0",
  "description": "Backend API for Book My Tickets",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "db:migrate": "node scripts/run-sql-migrations.js",
    "db:migrate:production": "node scripts/migrate-production-tidb.js",
    "db:migrate:production:full": "node scripts/migrate-production-tidb.js --backfill-slugs",
    "db:backfill-slugs": "node scripts/backfill-listing-slugs.js",
    "db:migrate:fresh": "node scripts/run-sql-migrations.js --bootstrap",
    "db:clone": "node scripts/clone-database.js",
    "db:clone:local-to-prod": "node scripts/clone-database.js",
    "db:prune-cities": "node scripts/prune-unused-cities.js",
    "db:seed": "node scripts/seed-local-dev.js",
    "e2e:platform-event": "node scripts/e2e-platform-event-admin-check.js",
    "local:stop-ports": "powershell -ExecutionPolicy Bypass -File scripts/stop-dev-ports.ps1",
    "build:frontend": "npm install --prefix frontend && npm run build --prefix frontend",
    "verify:production": "node scripts/verify-production-env.js",
    "prepare:deploy": "node scripts/prepare-production-deploy.js",
    "deploy:milesweb:env": "node scripts/generate-milesweb-deploy-env.js",
    "deploy:milesweb:build": "npm run deploy:milesweb:env && npm run build:frontend",
    "stripe:login": "powershell -ExecutionPolicy Bypass -File scripts/stripe-cli.ps1 login",
    "stripe:listen": "powershell -ExecutionPolicy Bypass -File scripts/stripe-cli.ps1 listen --forward-to http://localhost:5000/webhooks/stripe --events payment_intent.succeeded,payment_intent.payment_failed,payment_intent.canceled",
    "deploy:render": "node scripts/render-deploy.js",
    "sync:render-env": "node scripts/sync-render-env-from-local.js",
    "lint": "echo \"No linter configured yet\""
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@google-analytics/data": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "google-auth-library": "^9.15.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "mysql2": "^3.11.3",
    "stripe": "^17.7.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "nodemon": "^3.1.7"
  }
}
