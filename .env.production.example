# Copy to .env on the MilesWeb Node.js application root (API). Do NOT commit real .env.

NODE_ENV=production
PORT=5000

# TiDB Cloud production (same cluster as PRODUCTION_DB_* — MilesWeb only hosts the app)
DB_HOST=gateway01.ap-southeast-1.prod.aws.tidbcloud.com
DB_PORT=4000
DB_USER=your-tidb-user
DB_PASSWORD=your-tidb-password
DB_NAME=test
DB_SSL=true

JWT_ACCESS_SECRET=generate-at-least-32-random-characters-here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=generate-another-32-plus-character-secret
JWT_REFRESH_EXPIRES_IN=7d

CORS_ORIGIN=https://bookmytickets.us,https://www.bookmytickets.us

TRUST_PROXY_HOPS=1
APP_TIMEZONE=America/New_York
GA4_REPORTING_TIMEZONE=America/New_York

FRONTEND_URL=https://bookmytickets.us
PUBLIC_APP_URL=https://bookmytickets.us

# Google Sign-In (same client as frontend VITE_GOOGLE_CLIENT_ID)
GOOGLE_CLIENT_ID=

# Brevo email
BREVO_API_KEY=
BREVO_FROM_EMAIL=howdy@bookmytickets.us
BREVO_FROM_NAME=Book My Tickets
ADMIN_CONTACT_EMAIL=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=bookmytickets

# Stripe (live keys in production)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# GA4 organizer insights
GA4_PROPERTY_ID=
GA_SERVICE_ACCOUNT_JSON=

# City catalog
CSC_API_KEY=
CITY_SYNC_REFRESH_DAYS=30

# Seats.io reserved seating (https://app.seats.io/workspace-settings)
# Secret key = server + organizer designer; workspace key = public buyer chart
SEATSIO_SECRET_KEY=
SEATSIO_WORKSPACE_KEY=
SEATSIO_REGION=na

# Optional rate limits
# RATE_LIMIT_MAX=600
# RATE_LIMIT_WINDOW_MS=900000
