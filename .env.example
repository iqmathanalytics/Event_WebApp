NODE_ENV=development
PORT=5000

# Active connection for local dev (npm run dev, npm run db:migrate)
DB_HOST=your-tidb-host
DB_PORT=4000
DB_USER=your-user
DB_PASSWORD=your-password
DB_NAME=test
DB_SSL=true

# Production TiDB Cloud — app hosting is separate (e.g. MilesWeb); run: npm run db:migrate:production
# PRODUCTION_DB_HOST=gateway01.prod.aws.tidbcloud.com
# PRODUCTION_DB_PORT=4000
# PRODUCTION_DB_USER=your-prod-user
# PRODUCTION_DB_PASSWORD=your-prod-password
# PRODUCTION_DB_NAME=test
# PRODUCTION_DB_SSL=true

JWT_ACCESS_SECRET=replace-with-strong-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-strong-secret
JWT_REFRESH_EXPIRES_IN=7d

# Comma-separated browser origins allowed to call the API (credentials). Add extra origins if needed.
# Local: Vite default. Production may use http until SSL: http://bookmytickets.us,https://bookmytickets.us,...
CORS_ORIGIN=http://localhost:5173

# Production API (behind a reverse proxy): trust X-Forwarded-For so rate limits apply per real client IP.
# Set TRUST_PROXY_HOPS=2 if you have proxy + CDN in front. Omit in local dev.
# TRUST_PROXY_HOPS=1

# Global HTTP rate limit (express-rate-limit). Defaults: 300 requests per 15 minutes per IP.
# RATE_LIMIT_MAX=600
# RATE_LIMIT_WINDOW_MS=900000
# Emergency switch (not recommended long term): disable app rate limiting completely.
# RATE_LIMIT_DISABLED=true

# Google Sign-In (Web client ID from Google Cloud Console → APIs & Services → Credentials)
# Must match the frontend VITE_GOOGLE_CLIENT_ID (same OAuth 2.0 Client ID).
# GOOGLE_CLIENT_ID=

# Google Analytics 4 — organizer event insights (Data API + gtag on the site)
# 1) Create a GA4 property and web data stream; copy Measurement ID (G-XXXXXXXX) to frontend.
# 2) Admin → Custom definitions → Create custom dimension: Event parameter "bmt_event_id" (Event scope).
# 3) Create a service account with Analytics Viewer on the property; paste JSON as one line below.
# GA4_PROPERTY_ID=123456789
# Match GA4 Admin → Property settings → Reporting time zone (default: APP_TIMEZONE)
# GA4_REPORTING_TIMEZONE=America/New_York
# GA_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# One-time only — grant GA4 Viewer to the service account (scripts/grant-ga4-service-account-access.js --oauth):
# GOOGLE_OAUTH_CLIENT_ID=....apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=...

# Transactional email — Brevo (https://app.brevo.com). Sender must be verified in Brevo (tickets@bookmytickets.us).
# See docs/BREVO-EMAIL-SETUP.md for API key, domain, and when each email is sent.
# BREVO_API_KEY=xkeysib-...
# BREVO_FROM_EMAIL=tickets@bookmytickets.us
# BREVO_FROM_NAME=Book My Tickets
# Inbox for contact-form notifications (defaults to BREVO_FROM_EMAIL if unset):
# ADMIN_CONTACT_EMAIL=
# (or) ADMIN_NOTIFICATION_EMAIL=
# Public site URL for links inside emails (welcome, approval CTAs):
# FRONTEND_URL=https://bookmytickets.us
# PUBLIC_APP_URL=https://bookmytickets.us

# Optional: Mailchimp (sync DB subscribers). API key ends with -us21 etc.
# MAILCHIMP_SERVER_PREFIX must be the datacenter only (e.g. us21), not a full URL — required on Render/production.
# MAILCHIMP_API_KEY=
# MAILCHIMP_LIST_ID=
# MAILCHIMP_SERVER_PREFIX=us21

# Country-State-City sync (optional but recommended for dynamic US city catalog)
CSC_API_KEY=your-countrystatecity-api-key
CITY_SYNC_REFRESH_DAYS=30

# Cloudinary (image uploads from the app). Create credentials in the Cloudinary console.
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# Optional folder prefix for uploaded assets (default: bookmytickets)
# CLOUDINARY_UPLOAD_FOLDER=bookmytickets

# Stripe (platform ticket checkout). Webhook: POST https://your-api/webhooks/stripe
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# Live webhook signing secret (Dashboard → Developers → Webhooks → live endpoint → Signing secret):
# STRIPE_WEBHOOK_SECRET=whsec_...
# Production URL: https://www.bookmytickets.us/api/webhooks/stripe
# See docs/STRIPE-LIVE-WEBHOOK.md

# Optional: trigger Render redeploys from your machine (`npm run deploy:render`)
# RENDER_API_KEY=rnd_...
# RENDER_SERVICE_NAME=city-events-lifestyle-hub-api
# RENDER_SERVICE_ID=srv-...
