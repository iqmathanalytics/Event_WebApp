NODE_ENV=development
PORT=5000

DB_HOST=your-tidb-host
DB_PORT=4000
DB_USER=your-user
DB_PASSWORD=your-password
DB_NAME=city_events_hub
DB_SSL=true

JWT_ACCESS_SECRET=replace-with-strong-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-strong-secret
JWT_REFRESH_EXPIRES_IN=7d

CORS_ORIGIN=http://localhost:5173

# Google Sign-In (Web client ID from Google Cloud Console → APIs & Services → Credentials)
# Must match the frontend VITE_GOOGLE_CLIENT_ID (same OAuth 2.0 Client ID).
# GOOGLE_CLIENT_ID=

# Optional: SendGrid (contact form email to admin). From address must be a verified sender/domain in SendGrid.
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=
# SENDGRID_FROM_NAME=Yay! Tickets
# ADMIN_CONTACT_EMAIL=
# (or) ADMIN_NOTIFICATION_EMAIL=

# Optional: Mailchimp (sync DB subscribers). API key ends with -us5 etc.; use only the datacenter as prefix (us5), not the admin site URL.
# MAILCHIMP_API_KEY=
# MAILCHIMP_LIST_ID=
# MAILCHIMP_SERVER_PREFIX=us5

# Country-State-City sync (optional but recommended for dynamic US city catalog)
CSC_API_KEY=your-countrystatecity-api-key
CITY_SYNC_REFRESH_DAYS=30
