NODE_ENV=development
PORT=5000

DB_HOST=your-tidb-host
DB_PORT=4000
DB_USER=your-user
DB_PASSWORD=your-password
DB_NAME=city_events_hub
DB_SSL=true

JWT_ACCESS_SECRET=replace-with-strong-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-strong-secret
JWT_REFRESH_EXPIRES_IN=7d

CORS_ORIGIN=http://localhost:5173

# Production API (behind a reverse proxy): trust X-Forwarded-For so rate limits apply per real client IP.
# Set TRUST_PROXY_HOPS=2 if you have proxy + CDN in front. Omit in local dev.
# TRUST_PROXY_HOPS=1

# Global HTTP rate limit (express-rate-limit). Defaults: 300 requests per 15 minutes per IP.
# RATE_LIMIT_MAX=600
# RATE_LIMIT_WINDOW_MS=900000

# Google Sign-In (Web client ID from Google Cloud Console → APIs & Services → Credentials)
# Must match the frontend VITE_GOOGLE_CLIENT_ID (same OAuth 2.0 Client ID).
# GOOGLE_CLIENT_ID=

# Optional: SendGrid (contact form email to admin). From address must be a verified sender/domain in SendGrid.
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=
# SENDGRID_FROM_NAME=Yay! Tickets
# ADMIN_CONTACT_EMAIL=
# (or) ADMIN_NOTIFICATION_EMAIL=

# Optional: Mailchimp (sync DB subscribers). API key ends with -us21 etc.
# MAILCHIMP_SERVER_PREFIX must be the datacenter only (e.g. us21), not a full URL — required on Render/production.
# MAILCHIMP_API_KEY=
# MAILCHIMP_LIST_ID=
# MAILCHIMP_SERVER_PREFIX=us21

# Country-State-City sync (optional but recommended for dynamic US city catalog)
CSC_API_KEY=your-countrystatecity-api-key
CITY_SYNC_REFRESH_DAYS=30

# Optional: trigger Render redeploys from your machine (`npm run deploy:render`)
# RENDER_API_KEY=rnd_...
# RENDER_SERVICE_NAME=city-events-lifestyle-hub-api
# RENDER_SERVICE_ID=srv-...
