VITE_API_BASE_URL=http://localhost:5000

# Seats.io public workspace key (same region as backend SEATSIO_REGION)
# VITE_SEATSIO_REGION=na

# Production: set if the API is NOT same-origin /api (e.g. subdomain):
# VITE_API_BASE_URL=https://www.bookmytickets.us/api

# Same OAuth 2.0 Web client ID as backend GOOGLE_CLIENT_ID
# VITE_GOOGLE_CLIENT_ID=

# Stripe publishable key (must match backend STRIPE_PUBLISHABLE_KEY)
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Google Analytics 4 measurement ID (same property as backend GA4_PROPERTY_ID)
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
